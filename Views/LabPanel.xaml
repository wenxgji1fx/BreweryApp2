<UserControl x:Class="BreweryApp.Views.LabPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto"
             Height="Auto">
    <Grid Margin="18"
          Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Панель лаборанта"
                       Style="{StaticResource PageTitleTextStyle}"/>

            <TextBlock Text="Контроль качества партий и изменение статуса проверки по выбранной записи."
                       Style="{StaticResource PageSubtitleTextStyle}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}">
            <DataGrid Name="QualityDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код контроля"
                                        Binding="{Binding КодКонтроля}"
                                        Width="110"/>

                    <DataGridTextColumn Header="Партия"
                                        Binding="{Binding Партия}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Тип контроля"
                                        Binding="{Binding ТипКонтроля}"
                                        Width="160"/>

                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Дата}"
                                        Width="140"/>

                    <DataGridTextColumn Header="Статус"
                                        Binding="{Binding Статус}"
                                        Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SoftPanelStyle}">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Name="StartCheckButton"
                        Content="Начать проверку"
                        Click="StartCheck_Click"
                        ToolTip="Запустить проверку для выбранной партии."/>

                <Button Name="FinishCheckButton"
                        Content="Завершить проверку"
                        Click="FinishCheck_Click"
                        IsEnabled="False"
                        Style="{StaticResource SecondaryButtonStyle}"
                        ToolTip="Завершить проверку и установить статус «Проверена»."/>

                <Button Name="ResetCheckButton"
                        Content="Сбросить статус"
                        Click="ResetCheck_Click"
                        Style="{StaticResource OutlineButtonStyle}"
                        ToolTip="Сбросить статус выбранной партии обратно на «Не проверена»."/>

                <Border Margin="16,0,0,0"
                        Background="#5D6F34"
                        BorderBrush="#8DAA55"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,10">
                    <TextBlock Name="StatusText"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>