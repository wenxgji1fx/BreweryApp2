<Window x:Class="BreweryApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="520"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource SidebarGradientBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarGradientBrush}">
            <Grid Margin="34">
                <StackPanel VerticalAlignment="Center">
                    <Border Width="88"
                            Height="88"
                            CornerRadius="44"
                            Background="#33FFFFFF"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,22">
                        <TextBlock Text="🍺"
                                   FontSize="70"
                                   HorizontalAlignment="Left" Width="96" Height="100" VerticalAlignment="Top" Margin="4,-12,0,0"/>
                    </Border>

                    <TextBlock Text="Brewery App"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#D9901A"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Единая цифровая система управления пивоварней: сотрудники, варки, склад, заказы, лаборатория и агрономия в одном красивом интерфейсе."
                               FontSize="16"
                               Foreground="#F8F1E8"
                               TextWrapping="Wrap"
                               Margin="0,0,0,26"/>

                    <WrapPanel>
                        <Border Style="{StaticResource SoftPanelStyle}"
                                Background="#30FFFFFF"
                                BorderBrush="#20FFFFFF"
                                Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Удобство"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Единый стиль и понятная навигация"
                                           Foreground="#FFF6E8"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SoftPanelStyle}"
                                Background="#30FFFFFF"
                                BorderBrush="#20FFFFFF"
                                Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Text="Контроль"
                                           Foreground="White"
                                           FontWeight="Bold"/>
                                <TextBlock Text="Работа с заказами, задачами и качеством"
                                           Foreground="#FFF6E8"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="36">
            <Border Style="{StaticResource CardStyle}"
                    VerticalAlignment="Center"
                    Padding="30">
                <StackPanel>
                    <TextBlock Text="Добро пожаловать"
                               Style="{StaticResource PageTitleTextStyle}"/>

                    <TextBlock Text="Войдите в систему, чтобы открыть рабочую панель по вашей роли."
                               Style="{StaticResource PageSubtitleTextStyle}"/>

                    <TextBlock Text="Логин"
                               Style="{StaticResource FieldLabelTextStyle}"/>

                    <TextBox Name="LoginBox"
                             ToolTip="Введите логин пользователя. Например: admin, manager, brewer."/>

                    <TextBlock Text="Пароль"
                               Style="{StaticResource FieldLabelTextStyle}"/>

                    <PasswordBox Name="PasswordBox"
                                 ToolTip="Введите пароль от учетной записи. Подсказка появляется рядом с полем плавно."/>

                    <Button Content="Войти"
                            Margin="0,16,0,0"
                            Height="46"
                            Click="Login_Click"
                            ToolTip="Нажмите, чтобы войти в систему с указанными данными."/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>