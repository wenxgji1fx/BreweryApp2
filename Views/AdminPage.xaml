<Page x:Class="BreweryApp.Views.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Панель администратора"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Name="EmployeeIdBox" Width="100" Margin="5"/>
            <TextBox Name="LoginBox" Width="150" Margin="5"/>
            <TextBox Name="PasswordBox" Width="150" Margin="5"/>
            <TextBox Name="RoleIdBox" Width="100" Margin="5"/>
            <Button Content="Создать пользователя" Click="CreateUser_Click"/>
        </StackPanel>

        <DataGrid Name="UsersGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>
    </Grid>
</Page>