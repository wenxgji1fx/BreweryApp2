<Page x:Class="BreweryApp.Views.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="StockPage">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Остатки готовой продукции"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid Name="StockGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Margin="0,10,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Обновить" Click="Refresh_Click"/>
        </StackPanel>
    </Grid>
</Page>