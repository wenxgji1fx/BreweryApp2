<Page x:Class="BreweryApp.Views.DriverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid Margin="18">
        <StackPanel>
            <TextBlock Text="Панель Водителя-экспедитора"
                       Style="{StaticResource PageTitleTextStyle}"/>
            <TextBlock Text="Просмотр назначенных маршрутов и путевых листов."
                       Style="{StaticResource PageSubtitleTextStyle}"/>
            <DataGrid Name="DriverRoutesDataGrid" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Маршрут" Binding="{Binding RouteName}" Width="*"/>
                    <DataGridTextColumn Header="Продукция" Binding="{Binding Product}" Width="*"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="*"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>