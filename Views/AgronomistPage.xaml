<Page x:Class="BreweryApp.Views.AgronomistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl Margin="15">
        <TabItem Header="Участки">
            <DataGrid Name="FieldsGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
        </TabItem>
        <TabItem Header="Посевы">
            <DataGrid Name="SowingGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
        </TabItem>
        <TabItem Header="Процессы выращивания">
            <DataGrid Name="GrowingGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
        </TabItem>
        <TabItem Header="Урожай">
            <DataGrid Name="HarvestGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
        </TabItem>
    </TabControl>
</Page>