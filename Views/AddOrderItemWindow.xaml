<Window x:Class="BreweryApp.Views.AddOrderItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Позиция заказа"
        Height="260"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Партия готовой продукции"/>
            <ComboBox Name="ProductBox"
                      DisplayMemberPath="Display"
                      SelectedValuePath="КодПартииГотовойПродукции"/>

            <TextBlock Text="Количество"/>
            <TextBox Name="QuantityBox"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить" Click="Save_Click"/>
                <Button Content="Отмена" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>